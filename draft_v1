/************************************************************
===================== SETUP ================================
************************************************************/

unsigned long microsPrevious;
unsigned long microsPerReading;

void setup()
{

Serial.begin(115200);

delay(3000);

/* MOTOR INIT */

pinMode(dirPinL, OUTPUT);
pinMode(brakePinL, OUTPUT);

pinMode(dirPinR, OUTPUT);
pinMode(brakePinR, OUTPUT);

digitalWrite(brakePinL, HIGH);
digitalWrite(brakePinR, HIGH);

ledcAttach(pwmPinL, pwmFreq, pwmResolution);
ledcAttach(pwmPinR, pwmFreq, pwmResolution);


/* WIFI */

WiFi.mode(WIFI_AP);
WiFi.softAP(ssid,password);

Serial.println(WiFi.softAPIP());


/* IMU */

Wire.begin(SDA_PIN,SCL_PIN);

if(!BMI160.begin(BMI160GenClass::I2C_MODE,IMU_ADDR))
{
  Serial.println("IMU ERROR");
  while(1);
}

BMI160.setAccelerometerRate(100);
BMI160.setGyroRate(100);

calibrateGyro();

filter.begin(100);

Serial.println("IMU stabilizing");

unsigned long startTime = millis();

while(millis()-startTime < 5000)
{
  int ax,ay,az;
  int gx,gy,gz;

  BMI160.readAccelerometer(ax,ay,az);
  BMI160.readGyro(gx,gy,gz);

  filter.updateIMU(
    (gx-gyroBiasX)/131.0,
    (gy-gyroBiasY)/131.0,
    (gz-gyroBiasZ)/131.0,
    ax/16384.0,
    ay/16384.0,
    az/16384.0);

  delay(5);
}

calibrateOrientation();


/* WEB ROUTES */

server.on("/",[](){
server.send(200,"text/html",getHTML());
});

server.on("/zero",[](){
calibrateOrientation();
server.send(200,"text/plain","zeroed");
});

server.on("/data",[](){

String json =
"{\"roll\":"+String(roll,1)+
",\"pitch\":"+String(pitch,1)+
",\"yaw\":"+String(yaw,1)+
",\"leftMotor\":"+String(lastLeftPWM)+
",\"rightMotor\":"+String(lastRightPWM)+
",\"log\":\""+statusLog+"\"}";

server.send(200,"application/json",json);

});

server.begin();

microsPerReading = 5000;
microsPrevious = micros();

}


/************************************************************
===================== MAIN CONTROL LOOP =====================
************************************************************/

void loop()
{

server.handleClient();

if(micros()-microsPrevious >= microsPerReading)
{

int axR,ayR,azR;
int gxR,gyR,gzR;

BMI160.readAccelerometer(axR,ayR,azR);
BMI160.readGyro(gxR,gyR,gzR);

float gx=(gxR-gyroBiasX)/131.0;
float gy=(gyR-gyroBiasY)/131.0;
float gz=(gzR-gyroBiasZ)/131.0;

filter.updateIMU(
gx,gy,gz,
axR/16384.0,
ayR/16384.0,
azR/16384.0);

roll  = filter.getRoll()  - rollOffset;
pitch = filter.getPitch() - pitchOffset;
yaw   = filter.getYaw()   - yawOffset;


/* ===== BALANCE CONTROL ===== */

float error = roll;

integral += error;

float derivative = error - prevError;

float output =
Kp * error +
Ki * integral +
Kd * derivative;

prevError = error;


/* ===== SAFETY ===== */

if(abs(roll) > 35)
{
  setMotors(0);
}
else
{
  setMotors(output);
}

microsPrevious += microsPerReading;

}

}
