#include <MadgwickAHRS.h>

/************************************************************
===================== WIFI / WEBSERVER ======================
************************************************************/

const char* ssid = "ESP32_Robot_Monitor";
const char* password = "12345678";

WebServer server(80);

String statusLog = "System Ready";


/************************************************************
===================== MOTOR CONTROL =========================
Two ZS-X11H drivers
PWM 1kHz, 45% duty max
************************************************************/

// LEFT MOTOR
const int pwmPinL = 2;
const int dirPinL = 41;
const int brakePinL = 42;

// RIGHT MOTOR
const int pwmPinR = 3;
const int dirPinR = 40;
const int brakePinR = 39;

const int pwmFreq = 1000;
const int pwmResolution = 8;

const int maxPWM = 110;

int lastLeftPWM = 0;
int lastRightPWM = 0;

void setMotors(float value)
{
  int pwm = abs(value);

  if(pwm > maxPWM)
    pwm = maxPWM;

  if(pwm < 20)
    pwm = 0;

  if(value > 0)
  {
    digitalWrite(dirPinL, HIGH);
    digitalWrite(dirPinR, HIGH);
  }
  else
  {
    digitalWrite(dirPinL, LOW);
    digitalWrite(dirPinR, LOW);
  }

  ledcWrite(pwmPinL, pwm);
  ledcWrite(pwmPinR, pwm);

  lastLeftPWM = pwm;
  lastRightPWM = pwm;
}


/************************************************************
===================== IMU / GYRO ============================
BMI160 + Madgwick
************************************************************/

Madgwick filter;

#define SDA_PIN 39
#define SCL_PIN 40
#define IMU_ADDR 0x68

float roll = 0;
float pitch = 0;
float yaw = 0;

float rollOffset = 0;
float pitchOffset = 0;
float yawOffset = 0;

float gyroBiasX = 0;
float gyroBiasY = 0;
float gyroBiasZ = 0;

void calibrateGyro()
{
  Serial.println("Calibrating gyro");

  long gx=0,gy=0,gz=0;

  for(int i=0;i<2000;i++)
  {
    int x,y,z;
    BMI160.readGyro(x,y,z);

    gx+=x;
    gy+=y;
    gz+=z;

    delay(2);
  }

  gyroBiasX = gx/2000.0;
  gyroBiasY = gy/2000.0;
  gyroBiasZ = gz/2000.0;

  Serial.println("Gyro calibrated");
}

void calibrateOrientation()
{
  rollOffset  = filter.getRoll();
  pitchOffset = filter.getPitch();
  yawOffset   = filter.getYaw();

  Serial.println("Orientation zeroed");
}


/************************************************************
===================== PID BALANCE CONTROL ===================
************************************************************/

float Kp = 15;
float Ki = 0;
float Kd = 0.6;

float integral = 0;
float prevError = 0;


