#include <Wire.h>
#include <BMI160Gen.h>
#include <MadgwickAHRS.h>

// ================= IMU =================
Madgwick filter;

#define SDA_PIN 21
#define SCL_PIN 22
#define IMU_ADDR 0x68
#define UPDATE_HZ 100

unsigned long microsPerReading;
unsigned long microsPrevious;

// ================= GYRO CALIBRATION =================
float gyroBiasX = 0;
float gyroBiasY = 0;
float gyroBiasZ = 0;

// ================= FILTER =================
float ax_f=0, ay_f=0, az_f=0;
float gx_f=0, gy_f=0, gz_f=0;

float alpha = 0.15;

// ================= VALUES =================
float roll=0, pitch=0, yaw=0;


// ================= NORMALIZE =================
float normalize360(float angle){
  angle = fmod(angle,360.0);
  if(angle < 0) angle += 360.0;
  return angle;
}


// ================= CALIBRATION =================
void calibrateGyro(){

  Serial.println("Calibrating Gyro...");
  delay(2000);

  int samples = 500;

  long sumX=0;
  long sumY=0;
  long sumZ=0;

  int gx,gy,gz;

  for(int i=0;i<samples;i++){

    BMI160.readGyro(gx,gy,gz);

    sumX += gx;
    sumY += gy;
    sumZ += gz;

    delay(2);
  }

  gyroBiasX = (float(sumX)/samples)/131.0;
  gyroBiasY = (float(sumY)/samples)/131.0;
  gyroBiasZ = (float(sumZ)/samples)/131.0;

  Serial.println("Gyro calibration done");

  Serial.print("BiasX: "); Serial.println(gyroBiasX);
  Serial.print("BiasY: "); Serial.println(gyroBiasY);
  Serial.print("BiasZ: "); Serial.println(gyroBiasZ);
}


// ================= SETUP =================
void setup(){

  Serial.begin(115200);

  Wire.begin(SDA_PIN,SCL_PIN);

  if(!BMI160.begin(BMI160GenClass::I2C_MODE,IMU_ADDR)){
    Serial.println("BMI160 not detected");
    while(1);
  }

  BMI160.setAccelerometerRate(UPDATE_HZ);
  BMI160.setGyroRate(UPDATE_HZ);

  calibrateGyro();

  filter.begin(UPDATE_HZ);

  microsPerReading = 1000000/UPDATE_HZ;
  microsPrevious = micros();

  Serial.println("IMU Ready");
}


// ================= LOOP =================
void loop(){
  int axRaw,ayRaw,azRaw;
  int gxRaw,gyRaw,gzRaw;

  float ax,ay,az;
  float gx,gy,gz;

  unsigned long microsNow = micros();

  if(microsNow - microsPrevious >= microsPerReading){

    BMI160.readAccelerometer(axRaw,ayRaw,azRaw);
    BMI160.readGyro(gxRaw,gyRaw,gzRaw);

    ax = axRaw/16384.0;
    ay = ayRaw/16384.0;
    az = azRaw/16384.0;

    gx = (gxRaw/131.0) - gyroBiasX;
    gy = (gyRaw/131.0) - gyroBiasY;
    gz = (gzRaw/131.0) - gyroBiasZ;

    ax_f = alpha*ax + (1-alpha)*ax_f;
    ay_f = alpha*ay + (1-alpha)*ay_f;
    az_f = alpha*az + (1-alpha)*az_f;

    gx_f = alpha*gx + (1-alpha)*gx_f;
    gy_f = alpha*gy + (1-alpha)*gy_f;
    gz_f = alpha*gz + (1-alpha)*gz_f;

    filter.updateIMU(gx_f,gy_f,gz_f,ax_f,ay_f,az_f);

    roll  = normalize360(filter.getRoll());
    pitch = normalize360(filter.getPitch());
    yaw   = normalize360(filter.getYaw());

    Serial.print("Roll: ");
    Serial.print(roll);

    Serial.print(" Pitch: ");
    Serial.print(pitch);

    Serial.print(" Yaw: ");
    Serial.println(yaw);

    microsPrevious += microsPerReading;
  }

}
