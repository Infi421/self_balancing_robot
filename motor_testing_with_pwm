void loop() {

  int stepDelay = rampTime / maxPWM;
  digitalWrite(dirPin, HIGH);

  // Ramp up
  for(int pwm = 0; pwm <= maxPWM; pwm++){
    ledcWrite(pwmPin, pwm);
    delay(stepDelay);
  }
  // Ramp down
  for(int pwm = maxPWM; pwm >= 0; pwm--){
    ledcWrite(pwmPin, pwm);
    delay(stepDelay);
  }

  digitalWrite(dirPin, LOW);

      // Ramp up
  for(int pwm = 0; pwm <= maxPWM; pwm++){
    ledcWrite(pwmPin, pwm);
    delay(stepDelay);
  }
  // Ramp down
  for(int pwm = maxPWM; pwm >= 0; pwm--){
    ledcWrite(pwmPin, pwm);
    delay(stepDelay);
  }


}
