// PWM Generation Code

// Define the GPIO pin
const int pwmPin = 18; 

// PWM settings
const int frequency = 1000;   // 1 kHz
const int resolution = 8;     // 8-bit resolution (0-255)

void setup() {
  // Attach the pin to the PWM channel with freq and resolution
  // This automatically configures the PWM peripheral
  ledcAttach(2, frequency, resolution);
  ledcAttach(4, frequency, resolution);
  ledcAttach(5, frequency, resolution);

}

void loop() {
  // Set duty cycle to 50%
  // 50% of 255 (the max value for 8-bit) is approx 127
  ledcWrite(2, 70); 
  ledcWrite(4, 90); 
  ledcWrite(5, 110); 

}
