}

/******** WIFI ********/
void setupWiFi(){

  WiFi.softAP(ssid,password);

  server.on("/",[](){
    server.send(200,"text/html",getHTML());
  });

  server.on("/data",[](){
    char json[200];
    snprintf(json,sizeof(json),
      "{\"pitch\":%.2f,\"diff\":%.2f,\"rate\":%.2f,\"pwmL\":%d,\"pwmR\":%d,\"dirL\":%d,\"dirR\":%d}",
      currentAngle,
      error,
      (currentAngle - prevCompAngle)/sampleTime,
      pwmL, pwmR,
      dirL, dirR
    );
    server.send(200,"application/json",json);
  });

  server.on("/set",[](){
    if(server.hasArg("kp")) Kp = server.arg("kp").toFloat();
    if(server.hasArg("kd")) Kd = server.arg("kd").toFloat();
    server.send(200,"text/plain","OK");
  });

  server.on("/calibrate",[](){

    pwmL = pwmR = 0;
    analogWrite(pwmPinL, 0);
    analogWrite(pwmPinR, 0);

    server.send(200,"text/plain","Calibrating... KEEP STILL");

    delay(200);

    calibrateGyro();

    long sumY=0, sumZ=0;
    int ax,ay,az;

    for(int i=0;i<200;i++){
      BMI160.readAccelerometer(ax,ay,az);
      sumY += ay;
      sumZ += az;
      delay(2);
    }

    accY = sumY / 200;
    accZ = sumZ / 200;

    referenceAngle = atan2(accY, accZ)*RAD_TO_DEG;

    prevAngle = 0;
    currentAngle = 0;
    prevCompAngle = 0;

    errorSum = 0;
  });

  server.begin();
}

/******** GYRO CAL ********/
void calibrateGyro(){

  delay(2000);

  int gx,gy,gz;
  long sum=0;

  for(int i=0;i<500;i++){
    BMI160.readGyro(gx,gy,gz);
    sum += gx;
    delay(2);
  }

  gyroBiasX = (sum/500.0f) * GYRO_SCALE;
}

/******** CONTROL TASK ********/
void controlTask(void *pv){

  TickType_t xLastWakeTime = xTaskGetTickCount();
  int debugCount = 0;

  while(1){

    vTaskDelayUntil(&xLastWakeTime, pdMS_TO_TICKS(5));

    accAngle = atan2(accY, accZ)*RAD_TO_DEG;

    float gyroRate = (gyroX * GYRO_SCALE) - gyroBiasX;
    gyroAngle = gyroRate * sampleTime;

    float rawAngle =
      0.9934*(prevAngle + gyroAngle)
    + 0.0066*(accAngle);

    currentAngle = rawAngle - referenceAngle;

    error = currentAngle - targetAngle;

    if (fabs(error) < 1.0) {
      errorSum = 0;
    } else {
      errorSum += error;
      errorSum = constrain(errorSum, -300, 300);
    }

    motorPower =
        (Kp * error)
      + (Ki * errorSum * sampleTime)
      - (Kd * (currentAngle - prevCompAngle) / sampleTime);

    debugCount++;
    if(debugCount >= 5){
      debugCount = 0;

      Serial.print("AccAngle: "); Serial.print(accAngle);
      Serial.print(" | GyroRate: "); Serial.print(gyroRate);
      Serial.print(" | GyroAngle: "); Serial.print(gyroAngle);
      Serial.print(" | CompAngle: "); Serial.print(currentAngle);

      Serial.print(" | Error: "); Serial.print(error);
      Serial.print(" | dAngle: "); Serial.print((currentAngle - prevCompAngle) / sampleTime);
      Serial.print(" | Sum: "); Serial.print(errorSum);

      Serial.print(" | PWM: "); Serial.println(motorPower);
    }

    prevAngle = rawAngle;
    prevCompAngle = currentAngle;
  }
}

/******** SETUP ********/
void setup(){

  Serial.begin(115200);

  pinMode(pwmPinL,OUTPUT);
  pinMode(dirPinL,OUTPUT);
  pinMode(pwmPinR,OUTPUT);
  pinMode(dirPinR,OUTPUT);

  Wire.begin(SDA_PIN,SCL_PIN);
  BMI160.begin(BMI160GenClass::I2C_MODE,IMU_ADDR);

  delay(1000);

  long sumY = 0, sumZ = 0;
  int ax, ay, az;

  for(int i=0;i<300;i++){
    BMI160.readAccelerometer(ax,ay,az);
    sumY += ay;
    sumZ += az;
    delay(5);
  }

  float avgY = sumY / 300.0;
  float avgZ = sumZ / 300.0;

  referenceAngle = atan2(avgY, avgZ) * RAD_TO_DEG;

  prevAngle = referenceAngle;
  currentAngle = 0;
  prevCompAngle = 0;

  errorSum = 0;

  calibrateGyro();

  setupWiFi();

  xTaskCreatePinnedToCore(controlTask,"CTRL",4096,NULL,3,NULL,1);
}

/******** LOOP ********/
void loop(){

  int ax,ay,az,gx,gy,gz;

  BMI160.readAccelerometer(ax,ay,az);
  BMI160.readGyro(gx,gy,gz);

  accY = ay;
  accZ = az;
  gyroX = gx;

  int pwm = 0;

  if (fabs(error) < 30) {

    if (motorPower > 0) {
      dirL = 1;
      dirR = 0;
      pwm = motorPower;
    } else {
      dirL = 0;
      dirR = 1;
      pwm = -motorPower;
    }

     if (pwm > 0) pwm += 5;

    pwm = constrain(pwm, 0, maxPWM);

  } else {
    pwm = 0;
  }

  pwmL = pwm;
  pwmR = pwm;

  digitalWrite(dirPinL, dirL);
  digitalWrite(dirPinR, dirR);

  analogWrite(pwmPinL, pwmL);
  analogWrite(pwmPinR, pwmR);

  server.handleClient();
}
