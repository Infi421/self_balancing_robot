<div class="card"><div>Pitch Rate</div><div id="rate" class="val">0</div></div>

<div class="card"><div>PWM L</div><div id="pwmL" class="val">0</div></div>
<div class="card"><div>PWM R</div><div id="pwmR" class="val">0</div></div>

<div class="card"><div>Dir (L)</div><div id="dirL" class="val">S</div></div>
<div class="card"><div>Dir (R)</div><div id="dirR" class="val">S</div></div>

