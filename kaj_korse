/******** GYRO CAL ********/
void calibrateGyro(){
  delay(2000);
  int gx,gy,gz;
  long sx=0,sy=0,sz=0;

  for(int i=0;i<500;i++){
    BMI160.readGyro(gx,gy,gz);
    sx+=gx; sy+=gy; sz+=gz;
    delay(2);
  }

  float inv = 0.002f;
  gyroBiasX = (sx * inv) * GYRO_SCALE;
  gyroBiasY = (sy * inv) * GYRO_SCALE;
  gyroBiasZ = (sz * inv) * GYRO_SCALE;
}

/******** WIFI ********/
void setupWiFi(){

  WiFi.softAP(ssid,password);

  server.on("/",[](){
    server.send(200,"text/html",getHTML());
  });

  server.on("/data",[](){
    char json[200];
    snprintf(json,sizeof(json),
      "{\"pitch\":%.2f,\"diff\":%.2f,\"rate\":%.2f,\"pwmL\":%d,\"pwmR\":%d,\"dirL\":\"%s\",\"dirR\":\"%s\"}",
      pitch,diffVal,pitchRate,pwmL,pwmR,dirL_str.c_str(),dirR_str.c_str());

    server.send(200,"application/json",json);
  });

  server.on("/set",[](){
    if(server.hasArg("kp")) Kp = server.arg("kp").toFloat();
    if(server.hasArg("kd")) Kd = server.arg("kd").toFloat();
    server.send(200,"text/plain","OK");
  });

  // server.on("/calibrate",[](){
  //   pitchZero = filter.getPitch();
  //   server.send(200,"text/plain","OK");
  // });

server.on("/calibrate",[](){

  // 🔴 1. STOP MOTORS IMMEDIATELY
  pwmL = 0;
  pwmR = 0;
  digitalWrite(dirPinL, HIGH);
  digitalWrite(dirPinR, LOW);
  analogWrite(pwmPinL, 0);
  analogWrite(pwmPinR, 0);

  server.send(200,"text/plain","Calibrating... KEEP STILL");

  delay(200);

  // 🔥 2. GYRO CALIBRATION (same as startup)
  calibrateGyro();

  // 🔥 3. RESET FILTER
  filter.begin(UPDATE_HZ);

  // 🔥 4. ACCEL AVERAGE (same as setup)
  long sumAx=0,sumAy=0,sumAz=0;
  int ax,ay,az;

  for(int i=0;i<200;i++){
    BMI160.readAccelerometer(ax,ay,az);
    sumAx+=ax; sumAy+=ay; sumAz+=az;
    delay(2);
  }

  ax_f = (sumAx/200.0f)*ACC_SCALE;
  ay_f = (sumAy/200.0f)*ACC_SCALE;
  az_f = (sumAz/200.0f)*ACC_SCALE;

  // 🔥 5. FORCE MADGWICK CONVERGENCE (CRITICAL)
  for(int i=0;i<25000;i++){
    filter.updateIMU(0,0,0,ax_f,ay_f,az_f);
  }

  // 🔥 6. RE-CALCULATE ZERO (same as startup)
  float sumPitch=0;
  for(int i=0;i<100;i++){
    sumPitch+=filter.getPitch();
    delay(5);
  }

  pitchZero = sumPitch/100.0f;

});

  server.begin();
}

/******** CONTROL TASK ********/
void controlTask(void *pv){

  int axRaw,ayRaw,azRaw,gxRaw,gyRaw,gzRaw;

  while(1){

    if(micros()-prevMicros>=10000){

      prevMicros+=10000;

      BMI160.readAccelerometer(axRaw,ayRaw,azRaw);
      BMI160.readGyro(gxRaw,gyRaw,gzRaw);

      float ax=axRaw * ACC_SCALE;
      float ay=ayRaw * ACC_SCALE;
      float az=azRaw * ACC_SCALE;

      float gx=(gxRaw * GYRO_SCALE) - gyroBiasX;
      float gy=(gyRaw * GYRO_SCALE) - gyroBiasY;
      float gz=(gzRaw * GYRO_SCALE) - gyroBiasZ;

      ax_f = alpha_acc*ax + (1-alpha_acc)*ax_f; 
      ay_f = alpha_acc*ay + (1-alpha_acc)*ay_f;
      az_f = alpha_acc*az + (1-alpha_acc)*az_f;

      gx_f = alpha_gyro*gx + (1-alpha_gyro)*gx_f;
      gy_f = alpha_gyro*gy + (1-alpha_gyro)*gy_f;
      gz_f = alpha_gyro*gz + (1-alpha_gyro)*gz_f;

      filter.updateIMU(gx_f,gy_f,gz_f,ax_f,ay_f,az_f);

      pitch = filter.getPitch() - pitchZero;
      if(isnan(pitch)) pitch=0;

      pitchRate = -gy_f;

      pitchRate = constrain(pitchRate, -150, 150);

      diffVal = -pitch;

      // ===== OLD DEADBAND (COMMENTED AS REQUESTED) =====
      /*
      float diffChange = fabs(diffVal - prevDiffVal);

      if(diffChange >= 1.0f){
      }
      */

      // ===== NEW CORRECT PD CONTROL =====
      float error = -pitch;
      float output = (Kp * error) + (Kd * pitchRate);

      int pwm = 0;

      if (fabs(error) < 30) {

        if (output > 0) {
          dirL = 1;
          dirR = 0;
          pwm = output;
        } else {
          dirL = 0;
          dirR = 1;
          pwm = -output;
        }

        if (pwm > 0) pwm += 10;   // deadzone compensation

        pwm = constrain(pwm, 0, maxPWM);

      } else {
        dirL = 1;
        dirR = 0;
        pwm = 0;

        pwmL = 0;
        pwmR = 0;

        analogWrite(pwmPinL, 0);
        analogWrite(pwmPinR, 0);
      }

      pwmL = pwm;
      pwmR = pwm;

      if(pwmL==0) dirL_str="S";
      else if(dirL==1) dirL_str="F";
      else dirL_str="R";

      if(pwmR==0) dirR_str="S";
      else if(dirR==0) dirR_str="F";
      else dirR_str="R";

      digitalWrite(dirPinL,dirL);
      digitalWrite(dirPinR,dirR);

      analogWrite(pwmPinL,pwmL);
      analogWrite(pwmPinR,pwmR);

      Serial.print("Pitch: "); Serial.print(pitch);
      Serial.print(" | Rate: "); Serial.print(pitchRate);
      Serial.print(" | PWM: "); Serial.print(pwm);
      Serial.print(" | Dir: "); Serial.println(dirL_str);
    }
  }
}

/******** COMMS ********/
void commsTask(void *pv){
  while(1){
#if RUN_MODE == MODE_WIFI
    server.handleClient();
#endif
    vTaskDelay(20/portTICK_PERIOD_MS);
  }
}

/******** SETUP ********/
void setup(){

  Serial.begin(115200);

  pinMode(pwmPinL,OUTPUT);
  pinMode(dirPinL,OUTPUT);
  pinMode(pwmPinR,OUTPUT);
  pinMode(dirPinR,OUTPUT);

  Wire.begin(SDA_PIN,SCL_PIN);

  BMI160.begin(BMI160GenClass::I2C_MODE,IMU_ADDR);
  BMI160.setAccelerometerRate(UPDATE_HZ);
  BMI160.setGyroRate(UPDATE_HZ);

  calibrateGyro();
  filter.begin(UPDATE_HZ);

  long sumAx=0,sumAy=0,sumAz=0;
  int ax,ay,az;

  for(int i=0;i<200;i++){
    BMI160.readAccelerometer(ax,ay,az);
    sumAx+=ax; sumAy+=ay; sumAz+=az;
    delay(2);
  }

  ax_f = (sumAx/200.0f)*ACC_SCALE;
  ay_f = (sumAy/200.0f)*ACC_SCALE;
  az_f = (sumAz/200.0f)*ACC_SCALE;

  for(int i=0;i<25000;i++){
    filter.updateIMU(0,0,0,ax_f,ay_f,az_f);
  }

  float sumPitch=0;
  for(int i=0;i<100;i++){
    sumPitch+=filter.getPitch();
    delay(5);
  }
  pitchZero = sumPitch/100.0f;

#if RUN_MODE == MODE_WIFI
  setupWiFi();
#endif

  xTaskCreatePinnedToCore(controlTask,"CTRL",4096,NULL,3,NULL,1);
  xTaskCreatePinnedToCore(commsTask,"COMMS",4096,NULL,1,NULL,0);
}

void loop(){}
