/******** MODE ********/
#define MODE_SERIAL 1
#define MODE_WIFI   2
#define RUN_MODE MODE_WIFI

/******** WIFI ********/
const char* ssid = "ESP32_Robot";
const char* password = "12345678";
WebServer server(80);

/******** IMU ********/
Madgwick filter;

#define SDA_PIN 25
#define SCL_PIN 26
#define IMU_ADDR 0x68
#define UPDATE_HZ 100

/******** CONSTANTS ********/
#define ACC_SCALE 0.00006103515f
#define GYRO_SCALE 0.00763358f

/******** MOTOR ********/
const int pwmPinL = 27;
const int dirPinL = 14;
const int pwmPinR = 33;
const int dirPinR = 32;

const int maxPWM = 45;

/******** STATE ********/
volatile float pitch = 0;
volatile float diffVal = 0;

volatile int pwmL = 0, pwmR = 0;
volatile int dirL = 1, dirR = 0;

String dirL_str = "S";
String dirR_str = "S";

float pitchZero = 0;
float pitchRate = 0;

/******** PID ********/
float Kp = 2;
float Kd = 0.0;

/******** FILTER ********/
float ax_f=0, ay_f=0, az_f=0;
float gx_f=0, gy_f=0, gz_f=0;
float alpha_acc = 0.3f;
float alpha_gyro = 0.7f;


/******** GYRO ********/
float gyroBiasX=0, gyroBiasY=0, gyroBiasZ=0;

/******** TIMING ********/
unsigned long prevMicros = 0;

/******** DEADBAND ********/
float prevDiffVal = 0;

