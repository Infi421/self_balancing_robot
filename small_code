const int pwmPin = 2;     // connect to P
const int dirPin = 41;     // connect to DIR
const int brakePin = 42;   // connect to STOP

const int pwmChannel = 0;
const int pwmFreq = 1000;
const int pwmResolution = 8;

int maxPWM = 110;
int rampTime = 50000;   // 20 seconds

void setup() {

  pinMode(dirPin, OUTPUT);
  pinMode(brakePin, OUTPUT);

  digitalWrite(brakePin, HIGH); // release brake

  // attach PWM
  ledcAttach(pwmPin, pwmFreq, pwmResolution);

}


void loop() {

   digitalWrite(dirPin, HIGH);

  // Ramp up
    ledcWrite(2, 50);
    ledcWrite(4, 50);

    delay(500000);
  }
  


