#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <BMI160Gen.h>
#include <MadgwickAHRS.h>

/************************************************************
===================== WIFI / WEBSERVER ======================
************************************************************/
const char* ssid = "ESP32_Robot_Monitor";
const char* password = "12345678";

WebServer server(80);
String statusLog = "System Ready";

/************************************************************
===================== IMU / GYRO ============================
************************************************************/
Madgwick filter;

#define SDA_PIN 25
#define SCL_PIN 26
#define IMU_ADDR 0x68

float roll = 0, pitch = 0, yaw = 0;
float rollOffset = 0, pitchOffset = 0, yawOffset = 0;
float gyroBiasX = 0, gyroBiasY = 0, gyroBiasZ = 0;

bool imu_ok = false; 

void calibrateGyro() {
  statusLog = "Calibrating gyro...";
  long gx=0, gy=0, gz=0;
  for(int i=0; i<1000; i++) {
    int x,y,z;
    BMI160.readGyro(x,y,z);
    gx+=x; gy+=y; gz+=z;
    delay(2);
  }
  gyroBiasX = gx/1000.0;
  gyroBiasY = gy/1000.0;
  gyroBiasZ = gz/1000.0;
}

void calibrateOrientation() {
  if(!imu_ok) return; 
  rollOffset  = filter.getRoll();
  pitchOffset = filter.getPitch();
  yawOffset   = filter.getYaw();
  statusLog = "System Ready (Zeroed)";
}

/************************************************************
===================== WEB DASHBOARD =========================
************************************************************/
String getHTML() {
return R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
