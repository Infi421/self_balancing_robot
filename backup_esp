/************************************************************
===================== SETUP ================================
************************************************************/
unsigned long microsPrevious;
const unsigned long microsPerReading = 5000; // 200Hz

void setup() {
  Serial.begin(115200);
  delay(1000);

  /* WIFI AP */
  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);

  /* WEB ROUTES */
  server.on("/",[](){ server.send(200,"text/html",getHTML()); });
  server.on("/zero",[](){ calibrateOrientation(); server.send(200,"text/plain","zeroed"); });
  server.on("/data",[](){
    // Build JSON using snprintf (faster, less fragmentation)
    char json[128];
    snprintf(json, sizeof(json),
      "{\"roll\":%.1f,\"pitch\":%.1f,\"yaw\":%.1f,\"log\":\"%s\"}",
      roll, pitch, yaw, statusLog.c_str());
    server.send(200,"application/json",json);
  });
  server.begin();

  /* IMU AUTO-DETECT */
  Wire.begin(SDA_PIN, SCL_PIN);
  Wire.setClock(400000); // 400kHz Fast I2C
  Wire.setTimeOut(100); 

  Wire.beginTransmission(IMU_ADDR);
  if (Wire.endTransmission() == 0) {
    if(BMI160.begin(BMI160GenClass::I2C_MODE, IMU_ADDR)) {
      imu_ok = true;
      BMI160.setAccelerometerRate(100);
      BMI160.setGyroRate(100);
      calibrateGyro();
      filter.begin(100);
      calibrateOrientation();
    }
  } else {
    statusLog = "IMU Missing - Web Only Mode";
  }

  microsPrevious = micros();
}

/************************************************************
===================== MAIN LOOP ============================
************************************************************/
void loop() {
  // Handle web server traffic first
  server.handleClient();

  // Run IMU and Serial logic at exactly 200 Hz
  if(imu_ok && (micros() - microsPrevious >= microsPerReading)) {
    // Advance timer by the period, not set to current time (avoids bursts)
    microsPrevious += microsPerReading;

    int axR, ayR, azR, gxR, gyR, gzR;
    BMI160.readAccelerometer(axR, ayR, azR);
    BMI160.readGyro(gxR, gyR, gzR);

    // Filter update (Core math)
    filter.updateIMU(
      (gxR - gyroBiasX) / 131.0,
      (gyR - gyroBiasY) / 131.0,
      (gzR - gyroBiasZ) / 131.0,
      axR / 16384.0,
      ayR / 16384.0,
      azR / 16384.0
    );

    roll  = filter.getRoll()  - rollOffset;
    pitch = filter.getPitch() - pitchOffset;
    yaw   = filter.getYaw()   - yawOffset;

    // Output data only occasionally to avoid serial blocking
    static int serialCounter = 0;
    if (++serialCounter >= 40) {  // every 40 updates = 200 ms at 200 Hz
      Serial.print(roll);
      Serial.print(",");
      Serial.print(pitch);
      Serial.print(",");
      Serial.println(yaw);
      serialCounter = 0;
    }
  }

  // Give WiFi hardware a tiny break – helps stability
  delay(1);
}
